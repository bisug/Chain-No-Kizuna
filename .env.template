# ==========================================
# Chain no Kizuna - Environment Template
# ==========================================
# Copy this file to .env and fill in the values.

# --- Bot Tokens & Identity ---
# Main Telegram Bot Token (Get from @BotFather)
TOKEN=
# Virtual Player Bot Token (Optional, get from @BotFather)
VP_TOKEN=

# --- Database & Cache ---
# MongoDB connection URI (Get from MongoDB Atlas or local DB)
MONGO_URI=
# ◈ Leader Election
LOCK_TIMEOUT=30
RETRY_DELAY=5

# ◈ Support & Community
SUPPORT_GROUP=SuMelodyVibes
UPDATE_CHANNEL=SuMelodyVibes

 # (Get from Upstash or redis.io)
REDIS_URL=

# --- Administrative Configuration ---
# Your numeric Telegram user ID (Get from @userinfobot)
OWNER_ID=
# ID of the group where admin logs will be sent
ADMIN_GROUP_ID=0
# ID of the official game group
OFFICIAL_GROUP_ID=0
# ID of the channel where word additions are announced
WORD_ADDITION_CHANNEL_ID=0

# --- Permissions & Access ---
# Comma-separated list of VIP user IDs or JSON list
VIP=[]
# Comma-separated list of VIP group IDs or JSON list
VIP_GROUP=[]

# --- Logging ---
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
